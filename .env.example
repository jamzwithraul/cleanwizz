# ══════════════════════════════════════════════════════════════
# Clean Wizz — Environment Variables
# ══════════════════════════════════════════════════════════════
#
# RAILWAY (backend) — set all of these in Railway's Variables tab
# NETLIFY (frontend) — set VITE_BACKEND_URL in Netlify's Environment Variables
#
# Copy this file to .env for local development and fill in the values.
# Never commit .env to git.
# ══════════════════════════════════════════════════════════════

# ── Supabase (Railway only) ───────────────────────────────────
# Project URL from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role secret from: Supabase Dashboard → Settings → API → service_role
# WARNING: Never expose this key on the frontend. Railway/server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anon/public key (optional — not currently used by the backend)
SUPABASE_ANON_KEY=eyJ...

# ── Resend email (Railway only) ───────────────────────────────
# API key from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# From address — must use a domain verified in your Resend account
FROM_EMAIL=magic@harrietscleaning.ca

# Admin notification emails — sent on new contractor signup, new-client
# booking, and repeat-client booking. Defaults to admin@harryspottercleaning.ca.
ADMIN_NOTIFICATION_EMAIL=admin@harryspottercleaning.ca

# Optional — if set, overrides FROM_EMAIL for admin notifications specifically.
# EMAIL_FROM_ADDRESS=noreply@harryspottercleaning.ca
# EMAIL_FROM_NAME=Harry Spotter Cleaning Co.

# Feature flag — enables admin new-client/repeat-client booking notifications.
# Leave off until the jobs-table insert lands (fix/top5-blockers PR) so the
# prior-booking count is accurate. Set to "true" to enable.
ADMIN_BOOKING_NOTIFICATIONS_ENABLED=false

# Shared secret for internal webhooks (Supabase Auth → Express). Must match
# the X-Internal-Secret header configured on the Supabase Auth webhook.
INTERNAL_SERVICE_SECRET=replace-me-with-a-long-random-string

# ── URLs (Railway only) ───────────────────────────────────────
# The public URL of this Railway backend — used to build "Accept" links in emails.
# Set to your Railway deployment URL after first deploy.
BASE_URL=https://your-railway-app.up.railway.app

# The Netlify frontend URL — used for CORS. Set to your Netlify site URL.
# Use * to allow all origins (not recommended for production).
ALLOWED_ORIGIN=https://your-netlify-site.netlify.app

# ── Server (Railway only) ─────────────────────────────────────
# Railway sets PORT automatically — no need to set this manually.
PORT=5000

# Set to "true" only if serving frontend from the same Railway dyno.
# Leave unset (or "false") when frontend is on Netlify.
SERVE_STATIC=false

# ── Netlify frontend ─────────────────────────────────────────
# Public Railway backend URL — must be set as a Netlify environment variable
# with the VITE_ prefix so Vite bakes it into the frontend bundle.
# Set in: Netlify → Site Settings → Environment Variables
VITE_BACKEND_URL=https://your-railway-app.up.railway.app
